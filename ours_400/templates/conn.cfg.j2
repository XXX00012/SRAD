[connectivity]
# Ours400 {{ toppl_workers }}-worker / {{ parallel_lanes }}-lane board path:
#   {{ toppl_workers }} TopPL CUs each feed {{ worker_lanes }} AIE lanes.
#   AIE output uses pktmerge<{{ output_lanes_per_plio }}>, so each TopPL reads
#   {{ worker_lanes // output_lanes_per_plio }} grouped output streams.
#   Q0Ctrl reduces one partial sum/sum2 packet per TopPL worker and
#   broadcasts the global q0sqr back to each worker.
nk=TopPL:{{ toppl_workers }}:{% for worker in workers %}TopPL_{{ worker }}{% if not loop.last %}.{% endif %}{% endfor %}{{ "\n" }}
nk=Q0Ctrl:1:Q0Ctrl_1

# VCK190 base platforms normally expose a single DDR/LPDDR SP tag instead of
# indexed Alveo-style DDR[0] banks. Keep all worker AXI ports on the same tag
# so one host BO can be passed to all TopPL CUs.
{% for worker in workers %}
sp=TopPL_{{ worker }}.image:DDR
sp=TopPL_{{ worker }}.output:DDR
{% endfor %}
sp=Q0Ctrl_1.debug:DDR

{% for item in worker_lane_pairs %}
stream_connect=TopPL_{{ item.worker }}.out_j_{{ item.local_lane }}:ai_engine_0.{{ graph_id }}_in_j_{{ item.global_lane }}:32
{% endfor %}

{% for item in worker_output_group_pairs %}
stream_connect=ai_engine_0.{{ graph_id }}_out_j_next_{{ item.global_group }}:TopPL_{{ item.worker }}.in_j_next_{{ item.local_group }}:32
{% endfor %}

# Q0 is a PL-to-PL feedback loop. Insert link FIFOs so blocking AXIS reads
# and writes cannot deadlock on backpressure during the stats/q0 handshake.
{% for worker in workers %}
stream_connect=TopPL_{{ worker }}.stat_to_q0:Q0Ctrl_1.stat_in_{{ worker }}:16
{% endfor %}

{% for worker in workers %}
stream_connect=Q0Ctrl_1.q0_out_{{ worker }}:TopPL_{{ worker }}.q0_from_ctrl:16
{% endfor %}

# K1/K2 c values stay inside the AIE graph and are not materialized to PLIO/DDR.

[vivado]
prop=run.impl_1.STEPS.PLACE_DESIGN.ARGS.DIRECTIVE=EarlyBlockPlacement
prop=run.impl_1.STEPS.PHYS_OPT_DESIGN.IS_ENABLED=1
prop=run.impl_1.STEPS.PHYS_OPT_DESIGN.ARGS.DIRECTIVE=AggressiveExplore
prop=run.impl_1.STEPS.ROUTE_DESIGN.ARGS.DIRECTIVE=AggressiveExplore
